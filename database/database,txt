CREATE TABLE satuan (
    id_satuan   INT(11)     NOT NULL AUTO_INCREMENT,
    nama_satuan VARCHAR(50) NOT NULL,
    PRIMARY KEY (id_satuan)
) ENGINE=InnoDB
  DEFAULT CHARSET=utf8mb4
  COLLATE=utf8mb4_unicode_ci;

