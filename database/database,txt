CREATE TABLE riwayat_stok (
    id_riwayat INT(11)                             NOT NULL AUTO_INCREMENT,
    id_barang  INT(11)                             NOT NULL,
    jenis      ENUM('masuk','keluar','koreksi')    NOT NULL,
    jumlah     INT(11)                             NOT NULL,
    keterangan VARCHAR(255)                        DEFAULT NULL,
    tanggal    TIMESTAMP                           NOT NULL DEFAULT CURRENT_TIMESTAMP,
    PRIMARY KEY (id_riwayat),
    CONSTRAINT fk_riwayat_barang
        FOREIGN KEY (id_barang) REFERENCES barang(id)
        ON UPDATE CASCADE ON DELETE CASCADE
) ENGINE=InnoDB
  DEFAULT CHARSET=utf8mb4
  COLLATE=utf8mb4_unicode_ci;


CREATE OR REPLACE VIEW v_barang_lengkap AS
SELECT
    b.id,
    b.kode_barang,
    b.nama_barang,
    k.nama_kategori,
    s.nama_satuan,
    b.jumlah,
    b.harga,
    (b.jumlah * b.harga)    AS total_nilai,
    b.stok_minimum,
    b.lokasi,
    b.deskripsi,
    b.tanggal_masuk,
    b.tanggal_update,
    b.status,
    CASE
        WHEN b.jumlah = 0                THEN 'Habis'
        WHEN b.jumlah <= b.stok_minimum  THEN 'Stok Rendah'
        ELSE                                  'Aman'
    END AS kondisi_stok
FROM      barang    b
JOIN      kategori  k ON b.id_kategori = k.id_kategori
JOIN      satuan    s ON b.id_satuan   = s.id_satuan;
